# Shopify Storefront API (headless)
# Créer une "Custom App" dans votre Shopify Admin > Apps > Develop Apps
# Puis activer l'accès à la Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=votre-boutique.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=votre_storefront_access_token

# Optionnel : pour les webhooks Shopify
SHOPIFY_WEBHOOK_SECRET=votre_webhook_secret
